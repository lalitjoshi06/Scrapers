{
    "name": "BitSearch",
    "language": ["hi", "en"],
    "domains": ["bitsearch.to"],
    "base_url": "https://bitsearch.to",
    "search_url_format_episode": {
        "string_format": "/search?q=%s+s%02de%02d&sort=date&order=desc",
        "replacement": ["title_lower", "season_int", "episode_int"]
    },
    "search_url_format_movie": {
        "string_format": "/search?q=%s+%04d&sort=date&order=desc",
        "replacement": ["title_lower", "year_int"]
    },
    "search_url_format_season_pack": {
        "string_format": "/search?q=%s&sort=date&order=desc",
        "replacement": ["title_lower"]
    },
    "more_pages_indicator": "a[href*='page=']",
    "next_page_path": "a[href*='page=']",
    "next_page_path_attr": "href",
    "links_on_first_page": true,
    "drill_down_path": "",
    "drill_down_path_attr": "",
    "is_torrent": true,
    "is_direct": false,
    "links_container_path": "div.bg-white.rounded-lg.shadow-sm",
    "link_path": "a[href^='magnet']",
    "link_path_attr": "href",
    "title_path": "h3 a",
    "title_path_attr": "",
    "details_path": "h3 a",
    "details_path_attr": "href",
    "magnet_path": "a[href^='magnet']",
    "magnet_path_attr": "href",
    "seeders_path": "span.text-green-600 span.font-medium",
    "seeders_path_attr": "",
    "leechers_path": "span.text-red-600 span.font-medium",
    "leechers_path_attr": "",
    "filesize_path": "span.inline-flex:has(i.fa-download) span",
    "filesize_path_attr": "",
    "date_path": "span.inline-flex:has(i.fa-calendar) span",
    "date_path_attr": "",
    "quality_path": "h3 a",
    "quality_path_attr": "",
    "info_path": "h3 a",
    "info_path_attr": ""
}