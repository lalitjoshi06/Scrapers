{
    "name": "Solid-Torrent",
    "language": [
      "hi",
      "en"
    ],
    "domains": [
      "solidtorrents.to",
      "solidtorrents.eu"
    ],
    "base_url": "https://solidtorrents.to",
    "search_url_format_episode": {
      "string_format": "/search?q=%s+s%02de%02d&sort=date&order=desc",
      "replacement": [
        "title_lower",
        "season_int",
        "episode_int"
      ]
    },
    "search_url_format_movie": {
      "string_format": "/search?q=%s+%04d&sort=date&order=desc",
      "replacement": [
        "title_lower",
        "year_int"
      ]
    },
    "search_url_format_season_pack": {
      "string_format": "/search?q=%s&sort=date&order=desc",
      "replacement": [
        "title_lower"
      ]
    },
    "more_pages_indicator": "",
    "next_page_path": "",
    "next_page_path_attr": "",
    "links_on_first_page": true,
    "is_torrent": true,
    "is_direct": false,
    "links_container_path": "div.bg-white.rounded-lg.shadow-sm.border.border-gray-200.p-6.hover\\:shadow-md.transition.duration-150.ease-in-out",
    "link_path": "",
    "link_path_attr": "",
    "title_path": "h3.text-base.sm\\:text-lg.font-medium.text-gray-900.line-clamp-2 a",
    "title_path_attr": "",
    "details_path": "|title_path|",
    "details_path_attr": "",
    "magnet_path": "a[href^='magnet:']",
    "magnet_path_attr": "href",
    "filesize_path": "span.inline-flex.items-center.space-x-1:has(i.fas.fa-download) span:last-child",
    "filesize_path_attr": "",
    "seeders_path": "span.inline-flex.items-center.space-x-1.text-green-600 span.font-medium",
