{
  "name": "Tt2NZ",
  "language": ["hi", "en"],
  "domains": ["torrentz2.nz"],
  "base_url": "https://torrentz2.nz",

  "search_url_format_episode": {
    "string_format": "/search?q=%s+s%02de%02d",
    "replacement": ["title", "season_int", "episode_int"]
  },
  "search_url_format_movie": {
    "string_format": "/search?q=%s+%04d",
    "replacement": ["title", "year_int"]
  },

  "more_pages_indicator": "Next",
  "next_page_path": "a[rel=next]",
  "next_page_path_attr": "href",
  "links_on_first_page": false,
  "drill_down_path": "dl dt a[href^=/torrent]",
  "drill_down_path_attr": "abs:href",
  "is_torrent": true,
  "is_direct": false,
  "links_container_path": "div.download",
  "link_path": "div.download dl dt a[href^=/download/torrent]",
  "link_path_attr": "abs:href",
  "title_path": "div.download h2",
  "title_path_attr": "",
  "details_path": "div.download div",
  "details_path_attr": "",
  "magnet_path": "div.download dl dt a[href^=magnet]",
  "magnet_path_attr": "href",
  "seeders_path": "div.download div span[style*=009600]",
  "seeders_path_attr": "",
  "filesize_path": "div.download div",
  "filesize_path_attr": "",
  "quality_path": "div.download h2",
  "quality_path_attr": "",
  "info_path": "div.download h2",
  "info_path_attr": "",
  "leechers_path": "div.download div span[style*=003DB9]",
  "leechers_path_attr": ""
}