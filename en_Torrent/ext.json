{
  "name": "Extto",
  "language": ["hi", "en"],
  "domains": ["extto.org"],
  "base_url": "https://extto.org",
  "search_url_format_episode": {
    "string_format": "/browse/?filter=c=TV&q=%s+s%02de%02d",
    "replacement": [
      "title_lower",
      "season_int",
      "episode_int"
    ]
  },
  "search_url_format_movie": {
    "string_format": "/browse/?filter=c=Movies&q=%s+%04d",
    "replacement": [
      "title_lower",
      "year_int"
    ]
  },
  "search_url_format_season_pack": {
    "string_format": "/browse/?filter=c=TV&q=%s",
    "replacement": [
      "title_lower"
    ]
  },
  "is_torrent": true,
  "is_direct": false,
  "name_delete_filter": [],
  "links_on_first_page": true,
  "links_container_path": "tbody tr",
  "link_path": "",
  "link_path_attr": "",
  "title_path": "span.name b",
  "title_path_attr": "",
  "details_path": "a[href*=/post-detail/]",
  "details_path_attr": "href",
  "magnet_path": "a[href^=magnet]",
  "magnet_path_attr": "href",
  "seeders_path": "td:nth-child(5) span",
  "seeders_path_attr": "",
  "filesize_path": "td:nth-child(2) span",
  "filesize_path_attr": "",
  "quality_path": "|title_path|",
  "quality_path_attr": "",
  "info_path": "|title_path|",
  "info_path_attr": "",
  "more_pages_indicator": "",
  "next_page_path": "",
  "next_page_path_attr": "",
  "drill_down_path": "",
  "drill_down_path_attr": ""
}